# --- Ollama (local LLM) ---
OLLAMA_HOST=http://localhost:11434
# gemma4 gave the best answer quality/accuracy in testing (better than qwen2.5:14b and qwen3:32b,
# and faster than qwen3:32b) — production default.
# llama3.2 is a fine, lightweight fallback for local dev if you don't want to pull a ~9.6GB model.
OLLAMA_MODEL=gemma4

# --- Server ---
PORT=3000
# Comma-separated list of origins allowed to call this API cross-origin (needed for the embeddable widget)
CORS_ALLOWED_ORIGINS=https://alrouter.ai,https://www.alrouter.ai

# --- Confluence knowledge base (leave blank to disable) ---
CONFLUENCE_BASE_URL=https://your-domain.atlassian.net
# ID of the top-level page whose descendants should be used as the knowledge base
# (open the page in Confluence and check the URL, or use the REST API to find it)
CONFLUENCE_ROOT_PAGE_ID=
# Comma-separated page IDs to exclude from the knowledge base (e.g. pricing, internal-only docs)
CONFLUENCE_EXCLUDE_PAGE_IDS=
CONFLUENCE_EMAIL=you@company.com
CONFLUENCE_API_TOKEN=

# --- Slack alerts (leave blank to disable) ---
SLACK_WEBHOOK_URL=

# --- Google Chat alerts (leave blank to disable) ---
# Space > 앱 및 통합 관리 > 웹훅 추가 에서 발급
GOOGLE_CHAT_WEBHOOK_URL=

# --- Email alerts via SMTP (leave blank to disable) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_FROM=chatbot@alrouter.ai
ALERT_EMAIL_TO=support@alrouter.ai
