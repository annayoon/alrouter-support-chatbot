# --- Ollama (local LLM) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Server ---
PORT=3000

# --- Confluence knowledge base (leave blank to disable) ---
CONFLUENCE_BASE_URL=https://your-domain.atlassian.net
CONFLUENCE_SPACE_KEY=SUPPORT
CONFLUENCE_EMAIL=you@company.com
CONFLUENCE_API_TOKEN=

# --- Slack alerts (leave blank to disable) ---
SLACK_WEBHOOK_URL=

# --- Email alerts via SMTP (leave blank to disable) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_FROM=chatbot@alrouter.ai
ALERT_EMAIL_TO=support-team@alrouter.ai
